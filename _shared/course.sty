% ---------- Color palette (shared with style.sty) -----------
\definecolor{blueColor}{HTML}{1F4E79}
\definecolor{greenColor}{HTML}{0B6E4F}
\definecolor{redColor}{HTML}{B83227}
\definecolor{soft}{HTML}{F2F2F2}

% ---------- Hyperref setup ----------------------------------
\hypersetup{colorlinks=true, linkcolor=blueColor, urlcolor=blueColor}

% ---------- Chapter / section styling -----------------------
\titleformat{\chapter}[display]
  {\normalfont\Large\bfseries\color{blueColor}}
  {\chaptertitlename\ \thechapter}{12pt}{\Huge}
\titlespacing*{\chapter}{0pt}{-10pt}{20pt}

\titleformat{\section}
  {\normalfont\large\bfseries\color{blueColor}}
  {\thesection}{0.5em}{}
\titlespacing*{\section}{0pt}{14pt}{4pt}

\titleformat{\subsection}
  {\normalfont\normalsize\bfseries\color{blueColor!80!black}}
  {\thesubsection}{0.5em}{}
\titlespacing*{\subsection}{0pt}{8pt}{2pt}

\titleformat{\subsubsection}
  {\normalfont\normalsize\itshape\color{greenColor}}
  {\thesubsubsection}{0.5em}{}
\titlespacing*{\subsubsection}{0pt}{6pt}{2pt}

% ---------- Custom boxes ------------------------------------
\newtcolorbox{defnbox}[1][]{
  enhanced, colback=greenColor!8, colframe=greenColor,
  boxrule=0.5pt, arc=2pt, left=4pt, right=4pt, top=3pt, bottom=3pt,
  fonttitle=\bfseries\small, coltitle=white,
  colbacktitle=greenColor,
  attach boxed title to top left={yshift=-3pt, xshift=4pt},
  boxed title style={size=small, colback=greenColor, boxrule=0pt, arc=2pt},
  title=Definition, #1
}
\newtcolorbox{thmbox}[1][]{
  enhanced, colback=redColor!8, colframe=redColor,
  boxrule=0.5pt, arc=2pt, left=4pt, right=4pt, top=3pt, bottom=3pt,
  fonttitle=\bfseries\small, coltitle=white,
  colbacktitle=redColor,
  attach boxed title to top left={yshift=-3pt, xshift=4pt},
  boxed title style={size=small, colback=redColor, boxrule=0pt, arc=2pt},
  title=Theorem, #1
}
\newtcolorbox{propbox}[1][]{
  enhanced, colback=soft, colframe=blueColor,
  boxrule=0.5pt, arc=2pt, left=4pt, right=4pt, top=3pt, bottom=3pt,
  fonttitle=\bfseries\small, coltitle=white,
  colbacktitle=blueColor,
  attach boxed title to top left={yshift=-3pt, xshift=4pt},
  boxed title style={size=small, colback=blueColor, boxrule=0pt, arc=2pt},
  title=Property, #1
}
\newtcolorbox{warnbox}[1][]{
  enhanced, colback=white, colframe=redColor,
  boxrule=0.5pt, arc=2pt, left=4pt, right=4pt, top=3pt, bottom=3pt,
  fonttitle=\bfseries\small, coltitle=white,
  colbacktitle=redColor,
  attach boxed title to top left={yshift=-3pt, xshift=4pt},
  boxed title style={size=small, colback=redColor, boxrule=0pt, arc=2pt},
  title=Warning, #1
}
\newtcolorbox{exbox}[1][]{
  enhanced, colback=white, colframe=black!40,
  boxrule=0.4pt, arc=2pt, left=4pt, right=4pt, top=3pt, bottom=3pt,
  fonttitle=\bfseries\small, coltitle=black,
  colbacktitle=black!10,
  attach boxed title to top left={yshift=-3pt, xshift=4pt},
  boxed title style={size=small, colback=black!10, boxrule=0pt, arc=2pt},
  title=Example, #1
}
\newtcolorbox{rembox}[1][]{
  enhanced, colback=white, colframe=black!30,
  boxrule=0.4pt, arc=2pt, left=4pt, right=4pt, top=3pt, bottom=3pt,
  fonttitle=\bfseries\small\itshape, coltitle=black!70,
  colbacktitle=black!5,
  attach boxed title to top left={yshift=-3pt, xshift=4pt},
  boxed title style={size=small, colback=black!5, boxrule=0pt, arc=2pt},
  title=Remark, #1
}

