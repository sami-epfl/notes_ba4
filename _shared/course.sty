% ============================================================

% ---------- Color palette -----------------------------------
\definecolor{blueColor}{HTML}{1F4E79}
\definecolor{greenColor}{HTML}{0B6E4F}
\definecolor{redColor}{HTML}{B83227}
\definecolor{orangeColor}{HTML}{C45911}
\definecolor{soft}{HTML}{F2F2F2}

% ---------- Hyperref setup ----------------------------------
\hypersetup{
  colorlinks = true,
  linkcolor  = blueColor,
  urlcolor   = blueColor,
  citecolor  = blueColor,
}

% ---------- Paragraph spacing -------------------------------
\setlength{\parskip}{4pt plus 1pt}
\setlength{\parindent}{0pt}

% ---------- Chapter / section styling -----------------------
%
% Chapter: "CHAPTER N" label, huge title, coloured rule below
%
\titleformat{\chapter}[display]
  {\normalfont\bfseries\color{blueColor}\raggedright}
  {\large\MakeUppercase{\chaptertitlename}\ \thechapter}
  {4pt}
  {\huge}
  [{\vspace{4pt}\color{blueColor!40}\titlerule[1pt]}]
\titlespacing*{\chapter}{0pt}{-10pt}{20pt}

% Section: blue bold title + subtle rule underneath
\titleformat{\section}
  {\normalfont\large\bfseries\color{blueColor}}
  {\thesection}{0.6em}{}[{\color{blueColor!30}\titlerule[0.5pt]}]
\titlespacing*{\section}{0pt}{16pt}{6pt}

\titleformat{\subsection}
  {\normalfont\normalsize\bfseries\color{blueColor!85!black}}
  {\thesubsection}{0.5em}{}
\titlespacing*{\subsection}{0pt}{10pt}{3pt}

\titleformat{\subsubsection}
  {\normalfont\normalsize\itshape\color{greenColor}}
  {\thesubsubsection}{0.5em}{}
\titlespacing*{\subsubsection}{0pt}{7pt}{2pt}

% ---------- List defaults -----------------------------------
\setlist{itemsep=2pt, parsep=0pt, topsep=4pt}
\setlist[enumerate]{label=\arabic*.}

% ---------- Custom boxes ------------------------------------
%
%  defnbox  — Definition   (green)
%  thmbox   — Theorem      (red)
%  propbox  — Property     (blue)
%  warnbox  — Warning      (red border, light bg)
%  exbox    — Example      (gray)
%  rembox   — Remark       (light gray, italic header)
%  proofbox — Proof        (very light, italic header)
%  keybox   — Key Takeaway (orange)
%  algbox   — Algorithm    (blue-tinted)
%

\newtcolorbox{defnbox}[1][]{
  enhanced, colback=greenColor!7, colframe=greenColor,
  boxrule=0.5pt, arc=3pt, left=5pt, right=5pt, top=4pt, bottom=4pt,
  fonttitle=\bfseries\small, coltitle=white,
  colbacktitle=greenColor,
  attach boxed title to top left={yshift=-3pt, xshift=6pt},
  boxed title style={size=small, colback=greenColor, boxrule=0pt, arc=2pt},
  title=Definition, #1
}

\newtcolorbox{thmbox}[1][]{
  enhanced, colback=redColor!7, colframe=redColor,
  boxrule=0.5pt, arc=3pt, left=5pt, right=5pt, top=4pt, bottom=4pt,
  fonttitle=\bfseries\small, coltitle=white,
  colbacktitle=redColor,
  attach boxed title to top left={yshift=-3pt, xshift=6pt},
  boxed title style={size=small, colback=redColor, boxrule=0pt, arc=2pt},
  title=Theorem, #1
}

\newtcolorbox{propbox}[1][]{
  enhanced, colback=soft, colframe=blueColor,
  boxrule=0.5pt, arc=3pt, left=5pt, right=5pt, top=4pt, bottom=4pt,
  fonttitle=\bfseries\small, coltitle=white,
  colbacktitle=blueColor,
  attach boxed title to top left={yshift=-3pt, xshift=6pt},
  boxed title style={size=small, colback=blueColor, boxrule=0pt, arc=2pt},
  title=Property, #1
}

\newtcolorbox{warnbox}[1][]{
  enhanced, colback=redColor!5, colframe=redColor,
  boxrule=0.5pt, arc=3pt, left=5pt, right=5pt, top=4pt, bottom=4pt,
  fonttitle=\bfseries\small, coltitle=white,
  colbacktitle=redColor,
  attach boxed title to top left={yshift=-3pt, xshift=6pt},
  boxed title style={size=small, colback=redColor, boxrule=0pt, arc=2pt},
  title=Warning, #1
}

\newtcolorbox{exbox}[1][]{
  enhanced, colback=black!3, colframe=black!35,
  boxrule=0.4pt, arc=3pt, left=5pt, right=5pt, top=4pt, bottom=4pt,
  fonttitle=\bfseries\small, coltitle=black,
  colbacktitle=black!12,
  attach boxed title to top left={yshift=-3pt, xshift=6pt},
  boxed title style={size=small, colback=black!12, boxrule=0pt, arc=2pt},
  title=Example, #1
}

\newtcolorbox{rembox}[1][]{
  enhanced, colback=white, colframe=black!25,
  boxrule=0.4pt, arc=3pt, left=5pt, right=5pt, top=4pt, bottom=4pt,
  fonttitle=\bfseries\small\itshape, coltitle=black!65,
  colbacktitle=black!5,
  attach boxed title to top left={yshift=-3pt, xshift=6pt},
  boxed title style={size=small, colback=black!5, boxrule=0pt, arc=2pt},
  title=Remark, #1
}

\newtcolorbox{proofbox}[1][]{
  enhanced, colback=white, colframe=black!18,
  boxrule=0.4pt, arc=3pt, left=5pt, right=5pt, top=4pt, bottom=6pt,
  fonttitle=\bfseries\small\itshape, coltitle=black!55,
  colbacktitle=black!4,
  attach boxed title to top left={yshift=-3pt, xshift=6pt},
  boxed title style={size=small, colback=black!4, boxrule=0pt, arc=2pt},
  title=Proof, #1
}

\newtcolorbox{keybox}[1][]{
  enhanced, colback=orangeColor!8, colframe=orangeColor,
  boxrule=0.5pt, arc=3pt, left=5pt, right=5pt, top=4pt, bottom=4pt,
  fonttitle=\bfseries\small, coltitle=white,
  colbacktitle=orangeColor,
  attach boxed title to top left={yshift=-3pt, xshift=6pt},
  boxed title style={size=small, colback=orangeColor, boxrule=0pt, arc=2pt},
  title=Key Takeaway, #1
}

\newtcolorbox{algbox}[1][]{
  enhanced, colback=blueColor!5, colframe=blueColor!70,
  boxrule=0.5pt, arc=3pt, left=5pt, right=5pt, top=4pt, bottom=4pt,
  fonttitle=\bfseries\small, coltitle=white,
  colbacktitle=blueColor!80,
  attach boxed title to top left={yshift=-3pt, xshift=6pt},
  boxed title style={size=small, colback=blueColor!80, boxrule=0pt, arc=2pt},
  title=Algorithm, #1
}

