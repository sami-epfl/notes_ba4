}

% ---------- Title macro -------------------------------------
% Usage: \coursetitle{Course name}{Author}{Term}
\def\cn@course{Course Notes}
\def\cn@author{}
\def\cn@term{}
\newcommand{\coursetitle}[3]{%
  \gdef\cn@course{#1}%
  \gdef\cn@author{#2}%
  \gdef\cn@term{#3}%
  \begin{center}
    \begin{tcolorbox}[colback=blueColor, colframe=blueColor, arc=2pt,
      left=6pt, right=6pt, top=6pt, bottom=6pt, boxrule=0pt,
      width=\textwidth]
      \color{white}\LARGE\bfseries #1\\[4pt]
      \color{white!80}\normalsize #2 \textbullet\ #3
    \end{tcolorbox}
  \end{center}%
  \bigskip
}

