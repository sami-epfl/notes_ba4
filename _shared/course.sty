% ---------- Title macro -------------------------------------
% Usage: \coursetitle{Course name}{Author}{Term}
\def\cn@course{Course Notes}
\def\cn@author{}
\def\cn@term{}
\newcommand{\coursetitle}[3]{%
  \gdef\cn@course{#1}%
  \gdef\cn@author{#2}%
  \gdef\cn@term{#3}%
  \begin{center}
    \begin{tcolorbox}[
      colback=blueColor, colframe=blueColor, arc=4pt,
      left=12pt, right=12pt, top=12pt, bottom=12pt,
      boxrule=0pt, width=\textwidth
    ]
      \color{white}\LARGE\bfseries #1\\[6pt]
      \color{white!80}\normalsize\itshape #2 \quad\textbullet\quad #3
    \end{tcolorbox}
  \end{center}%
  \bigskip
}

